# Server
PORT=4000
NODE_ENV=development

# Debug Configuration
# DEBUG_STATE controls the verbosity of debug logging
# 0 = No debug output (production mode)
# 1 = Essential debugging (important state changes, errors, game flow)
# 2 = Verbose debugging (detailed logs for deep investigation)
# Default: 0
DEBUG_STATE=0

# SQLite
SQLITE_FILE=./data/mtgedh.sqlite

# Startup behavior
# Clear only persisted/in-memory games on startup. Saved decks are not touched.
WIPE_GAMES_ON_STARTUP=false

# Clear the local planeswalker cache at startup.
CLEAR_PLANESWALKER_CACHE=false

# Prebuild the local SQLite card lookup table used by deck import at startup.
# Disable only if you want to avoid the one-time warmup cost during boot.
LOCAL_CARD_LOOKUP_WARMUP=true

# Optional CORS origin override for the server.
# CORS_ORIGIN=http://localhost:3000

# Scryfall
SCRYFALL_BASE_URL=https://api.scryfall.com
SCRYFALL_USER_AGENT=MTGEDH/0.1 (+https://github.com/A2152225/MTGEDH)